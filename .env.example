# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + anon (publishable) key — safe for the browser. Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — fallback for auth redirects when proxy headers are absent
# (e.g. local dev). In production, Vercel's forwarded headers are used instead.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (Drizzle) ────────────────────────────────────────────────────────
# Postgres connection string for Drizzle (Supabase → Project Settings → Database).
# Use the pooled (transaction mode, port 6543) URL on serverless; direct (5432) for migrations.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ── AI providers (server only) ────────────────────────────────────────────────
# Google Gemini — default/economy model for drafts (Vercel AI SDK reads this name).
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Anthropic Claude — "deep" option for validation.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model overrides (defaults: gemini-2.5-flash / claude-sonnet-5).
# GEMINI_MODEL=gemini-flash-latest
# ANTHROPIC_MODEL=claude-sonnet-5

# ── Observability & email (wired in Phase 5; safe to leave empty until then) ──
# Resend — transactional email (verification, notifications).
RESEND_API_KEY=your-resend-api-key
# Sentry — error tracking (client + server).
SENTRY_DSN=your-sentry-dsn
# PostHog — product analytics (activation/retention funnel). Public, client-side.
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
